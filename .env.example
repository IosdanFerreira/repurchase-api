# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=*

# Database (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/repurchase_db

# Redis (Bull Queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# SMTP (E-mail)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_user
SMTP_PASS=your_pass

# Upload
UPLOAD_MAX_SIZE=2097152

# Session
SESSION_SECRET=your-session-secret-change-in-production

# Web WhatsApp API
WEB_WHATSAPP_API_URL=http://localhost:8080
WEB_WHATSAPP_API_KEY=your-web-whatsapp-api-key

# Sentry (Error Tracking)
SENTRY_DSN=
